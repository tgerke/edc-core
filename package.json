{
  "name": "edc-core",
  "private": true,
  "version": "0.3.0",
  "description": "A modern, open-source Electronic Data Capture (EDC) system for clinical research",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r --parallel test",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "dev": "pnpm -r --parallel dev",
    "validation-pack": "node scripts/validation-pack.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
