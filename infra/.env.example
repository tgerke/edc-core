# Production environment for infra/compose.prod.yaml. Copy to .env next to
# the compose file, fill in the required values, then:
#
#   docker compose -f compose.prod.yaml up -d
#
# Work through site/deployment.qmd (TLS, encryption at rest, paired backups,
# retention) before clinical data touches the system. Lines left commented
# out are simply absent from the API container — that is how its optional
# features stay off.

# ---- Required ---------------------------------------------------------------

# Hostname the stack is served on. Must resolve to this host for Caddy to
# obtain a certificate; use "localhost" only for a local smoke test.
EDC_DOMAIN=edc.example.org

# Released version to run (image tag, without the leading v). Pin an exact
# release — each one ships with its validation pack. Never "latest".
# v0.4.0 is the first release that publishes all five images (py-engine
# included); earlier tags predate the Python engine.
EDC_VERSION=0.4.0

# Password for the bundled PostgreSQL (local-db profile). Generate one:
#   openssl rand -base64 24
POSTGRES_PASSWORD=

# Which optional services run. local-db = the bundled PostgreSQL,
# engines = the R/Python analytics sidecars. Drop engines on small hosts;
# drop local-db when using a managed Postgres (set DATABASE_URL below).
COMPOSE_PROFILES=local-db,engines

# ---- Managed database (instead of the local-db profile) ---------------------

# Full connection string to a managed PostgreSQL 16+. When the connection
# crosses a host boundary, require TLS. Remove local-db from COMPOSE_PROFILES.
#DATABASE_URL=postgres://edc:...@db.internal:5432/edc?sslmode=verify-full

# ---- First admin ------------------------------------------------------------

# Used by the one-time bootstrap (prints a generated credential if unset):
#   docker compose -f compose.prod.yaml exec api pnpm --filter @edc-core/api db:bootstrap-admin
#EDC_ADMIN_EMAIL=admin@example.org
#EDC_ADMIN_USERNAME=admin

# ---- Single sign-on (OIDC) — see site/installation.qmd ----------------------

#EDC_OIDC_ISSUER_URL=https://login.example.org/realms/main
#EDC_OIDC_CLIENT_ID=edc-core
#EDC_OIDC_CLIENT_SECRET=
#EDC_OIDC_REDIRECT_URI=https://edc.example.org/api/auth/oidc/callback
#EDC_OIDC_SCOPES=openid profile email
#EDC_OIDC_PROVIDER_LABEL=Organization SSO
#EDC_OIDC_ONLY=0
#EDC_OIDC_REAUTH_MAX_AGE_SECONDS=120

# ---- Email notifications ----------------------------------------------------

# Setting the host enables email delivery of notifications.
#EDC_SMTP_HOST=smtp.example.org
#EDC_SMTP_PORT=587
#EDC_SMTP_SECURE=0
#EDC_SMTP_USER=
#EDC_SMTP_PASS=
#EDC_SMTP_FROM=edc-core <no-reply@example.org>

# ---- Authentication and session policy (review against your SOPs) -----------

# Values shown are the built-in defaults.
#EDC_PASSWORD_MIN_LENGTH=12
#EDC_MAX_FAILED_LOGINS=5
#EDC_LOCKOUT_MINUTES=15
#EDC_SESSION_IDLE_MINUTES=30
#EDC_SESSION_ABSOLUTE_HOURS=8

# ---- Scheduler and anomaly detection ----------------------------------------

#EDC_NOTIFY_SCAN_MINUTES=15
#EDC_FORM_OVERDUE_DAYS=0
#EDC_ANOMALY_FAILED_LOGIN_THRESHOLD=10
#EDC_ANOMALY_WINDOW_MINUTES=15
